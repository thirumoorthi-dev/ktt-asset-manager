extends ../layout

block content
  h2.fw-bold.mb-4 Department Master

  if error
    .alert.alert-danger.alert-dismissible.fade.show.mb-4(role="alert")
      i.fa-solid.fa-triangle-exclamation.me-2
      | #{error}
      button.btn-close(type="button" data-bs-dismiss="alert" aria-label="Close")

  .row.g-4
    .col-lg-8
      .card.border-0.shadow-sm
        .card-header.bg-transparent.border-bottom.py-3
          h5.fw-bold.mb-0 Registered Departments
        .card-body.p-4
          .table-responsive
            table#departmentsTable.table.table-striped.table-hover.align-middle(style="width: 100%")
              thead.table-dark
                tr
                  th Name
                  th Status
                  th Actions
              tbody
                if departments && departments.length > 0
                  each dept in departments
                    tr
                      td
                        span.fw-bold.text-dark #{dept.DepartmentName}
                      td
                        if dept.IsActive
                          span.badge.bg-success-subtle.text-success.px-2.py-1.border.border-success-subtle Active
                        else
                          span.badge.bg-danger-subtle.text-danger.px-2.py-1.border.border-danger-subtle Inactive
                      td
                        a.btn.btn-sm.btn-outline-primary(href=`/departments?edit=${dept.DepartmentId}`)
                          i.fa-solid.fa-pen-to-square.me-1
                          | Edit
                else
                  tr
                    td.text-center.text-muted(colspan="3") No departments found.
    
    .col-lg-4
      .card.border-0.shadow-sm
        .card-header.bg-transparent.border-bottom.py-3
          h5.fw-bold.mb-0 #{editDepartment ? 'Edit Department' : 'Add Department'}
        .card-body.p-4
          form(method="POST" action=(editDepartment ? `/departments/edit/${editDepartment.DepartmentId}` : "/departments/create"))
            .mb-3
              label.form-label.fw-semibold(for="DepartmentName") Department Name *
              input#DepartmentName.form-control(type="text" name="DepartmentName" value=(editDepartment ? editDepartment.DepartmentName : '') required placeholder="e.g. Engineering, Sales")
            
            if editDepartment
              .mb-4
                label.form-label.fw-semibold(for="IsActive") Status
                select#IsActive.form-select(name="IsActive")
                  option(value="true" selected=editDepartment.IsActive) Active
                  option(value="false" selected=!editDepartment.IsActive) Inactive

            .d-grid.gap-2
              button.btn.btn-primary(type="submit")
                i.fa-solid.fa-floppy-disk.me-2
                | #{editDepartment ? 'Update Department' : 'Save Department'}
              
              if editDepartment
                a.btn.btn-outline-secondary(href="/departments") Cancel Edit
