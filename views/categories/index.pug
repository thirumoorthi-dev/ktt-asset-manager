extends ../layout

block content
  h2.fw-bold.mb-4 Asset Category Master

  if error
    .alert.alert-danger.alert-dismissible.fade.show.mb-4(role="alert")
      i.fa-solid.fa-triangle-exclamation.me-2
      | #{error}
      button.btn-close(type="button" data-bs-dismiss="alert" aria-label="Close")

  .row.g-4
    .col-lg-8
      .card.border-0.shadow-sm
        .card-header.bg-transparent.border-bottom.py-3
          h5.fw-bold.mb-0 Registered Categories
        .card-body.p-4
          .table-responsive
            table#categoriesTable.table.table-striped.table-hover.align-middle(style="width: 100%")
              thead.table-dark
                tr
                  th Name
                  th Description
                  th Status
                  th Actions
              tbody
                if categories && categories.length > 0
                  each cat in categories
                    tr
                      td
                        span.fw-bold.text-dark #{cat.CategoryName}
                      td.text-muted.small #{cat.Description || '-'}
                      td
                        if cat.IsActive
                          span.badge.bg-success-subtle.text-success.px-2.py-1.border.border-success-subtle Active
                        else
                          span.badge.bg-danger-subtle.text-danger.px-2.py-1.border.border-danger-subtle Inactive
                      td
                        a.btn.btn-sm.btn-outline-primary(href=`/categories?edit=${cat.CategoryId}`)
                          i.fa-solid.fa-pen-to-square.me-1
                          | Edit
                else
                  tr
                    td.text-center.text-muted(colspan="4") No categories found.
    
    .col-lg-4
      .card.border-0.shadow-sm
        .card-header.bg-transparent.border-bottom.py-3
          h5.fw-bold.mb-0 #{editCategory ? 'Edit Category' : 'Add Category'}
        .card-body.p-4
          form(method="POST" action=(editCategory ? `/categories/edit/${editCategory.CategoryId}` : "/categories/create"))
            .mb-3
              label.form-label.fw-semibold(for="CategoryName") Category Name *
              input#CategoryName.form-control(type="text" name="CategoryName" value=(editCategory ? editCategory.CategoryName : '') required placeholder="e.g. Laptop, Mobile Phone")
            
            .mb-3
              label.form-label.fw-semibold(for="Description") Description
              textarea#Description.form-control(name="Description" rows="4" placeholder="Brief explanation...") #{editCategory ? editCategory.Description : ''}
            
            if editCategory
              .mb-4
                label.form-label.fw-semibold(for="IsActive") Status
                select#IsActive.form-select(name="IsActive")
                  option(value="true" selected=editCategory.IsActive) Active
                  option(value="false" selected=!editCategory.IsActive) Inactive

            .d-grid.gap-2
              button.btn.btn-primary(type="submit")
                i.fa-solid.fa-floppy-disk.me-2
                | #{editCategory ? 'Update Category' : 'Save Category'}
              
              if editCategory
                a.btn.btn-outline-secondary(href="/categories") Cancel Edit
