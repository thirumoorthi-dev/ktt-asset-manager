extends ../layout

block content
  h2.fw-bold.mb-4 Return Reason Master

  if error
    .alert.alert-danger.alert-dismissible.fade.show.mb-4(role="alert")
      i.fa-solid.fa-triangle-exclamation.me-2
      | #{error}
      button.btn-close(type="button" data-bs-dismiss="alert" aria-label="Close")

  .row.g-4
    .col-lg-8
      .card.border-0.shadow-sm
        .card-header.bg-transparent.border-bottom.py-3
          h5.fw-bold.mb-0 Registered Return Reasons
        .card-body.p-4
          .table-responsive
            table#returnReasonsTable.table.table-striped.table-hover.align-middle(style="width: 100%")
              thead.table-dark
                tr
                  th Reason Name
                  th Status
                  th Actions
              tbody
                if reasons && reasons.length > 0
                  each reason in reasons
                    tr
                      td
                        span.fw-bold.text-dark #{reason.ReasonName}
                      td
                        if reason.IsActive
                          span.badge.bg-success-subtle.text-success.px-2.py-1.border.border-success-subtle Active
                        else
                          span.badge.bg-danger-subtle.text-danger.px-2.py-1.border.border-danger-subtle Inactive
                      td
                        a.btn.btn-sm.btn-outline-primary(href=`/return-reasons?edit=${reason.ReasonId}`)
                          i.fa-solid.fa-pen-to-square.me-1
                          | Edit
                else
                  tr
                    td.text-center.text-muted(colspan="3") No reasons found.
    
    .col-lg-4
      .card.border-0.shadow-sm
        .card-header.bg-transparent.border-bottom.py-3
          h5.fw-bold.mb-0 #{editReason ? 'Edit Return Reason' : 'Add Return Reason'}
        .card-body.p-4
          form(method="POST" action=(editReason ? `/return-reasons/edit/${editReason.ReasonId}` : "/return-reasons/create"))
            .mb-3
              label.form-label.fw-semibold(for="ReasonName") Reason Name *
              input#ReasonName.form-control(type="text" name="ReasonName" value=(editReason ? editReason.ReasonName : '') required placeholder="e.g. Hardware Upgrade, Project Completed")
            
            if editReason
              .mb-4
                label.form-label.fw-semibold(for="IsActive") Status
                select#IsActive.form-select(name="IsActive")
                  option(value="true" selected=editReason.IsActive) Active
                  option(value="false" selected=!editReason.IsActive) Inactive

            .d-grid.gap-2
              button.btn.btn-primary(type="submit")
                i.fa-solid.fa-floppy-disk.me-2
                | #{editReason ? 'Update Reason' : 'Save Reason'}
              
              if editReason
                a.btn.btn-outline-secondary(href="/return-reasons") Cancel Edit
