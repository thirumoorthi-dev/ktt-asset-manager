extends ../layout

block content
  .row.justify-content-center
    .col-lg-8
      .card.border-0.shadow-sm
        .card-header.bg-transparent.border-bottom.py-3.d-flex.justify-content-between.align-items-center
          h4.fw-bold.mb-0 Return Asset from Employee
          a.btn.btn-sm.btn-outline-secondary(href="/assets") 
            i.fa-solid.fa-arrow-left.me-1
            | Back to Master
        .card-body.p-4
          form(method="POST" action="/assets/return")
            .mb-3
              label.form-label.fw-semibold(for="AssetId") Select Issued Asset *
              select#AssetId.form-select(name="AssetId" required)
                option(value="") -- Select Asset to Return --
                each asset in assets
                  option(value=asset.AssetId selected=(selectedAssetId === asset.AssetId)) #{asset.UniqueId} [#{asset.Make} #{asset.Model}] - With #{asset.CurrentEmployee ? asset.CurrentEmployee.EmployeeName : 'Unknown'}
              small.text-muted Lists only assets that are currently issued to staff.

            .row.g-3.mb-4
              .col-md-6
                label.form-label.fw-semibold(for="ReturnBranch") Target Return Branch *
                select#ReturnBranch.form-select(name="ReturnBranch" required)
                  option(value="") -- Select Branch --
                  if branches && branches.length > 0
                    each br in branches
                      option(value=br.BranchName) #{br.BranchName}
                small.text-muted Branch where the device is returned to stock.
              .col-md-6
                label.form-label.fw-semibold(for="ReturnDate") Return Date *
                input#ReturnDate.form-control(type="date" name="ReturnDate" required)

              .col-md-6
                label.form-label.fw-semibold(for="Reason") Reason for Return *
                select#Reason.form-select(name="Reason" required)
                  option(value="") -- Select Reason --
                  if returnReasons && returnReasons.length > 0
                    each rr in returnReasons
                      option(value=rr.ReasonName) #{rr.ReasonName}
              .col-md-6
                label.form-label.fw-semibold(for="Notes") Return Remarks / Condition
                textarea#Notes.form-control(name="Notes" rows="2" placeholder="e.g. Screen scratches, keyboard issues...")

            .d-grid
              button.btn.btn-primary.btn-lg(type="submit")
                i.fa-solid.fa-rotate-left.me-2
                | Confirm Return

    script.
      document.addEventListener('DOMContentLoaded', function() {
        document.getElementById('ReturnDate').valueAsDate = new Date();
      });
