extends ../layout

block content
  .row.justify-content-center
    .col-lg-9
      .card.border-0.shadow-sm
        .card-header.bg-transparent.border-bottom.py-3.d-flex.justify-content-between.align-items-center
          h4.fw-bold.mb-0 #{isEdit ? 'Edit Asset' : 'Add Asset'}
          a.btn.btn-sm.btn-outline-secondary(href="/assets")
            i.fa-solid.fa-arrow-left.me-1
            | Back to List
        .card-body.p-4
          if error
            .alert.alert-danger.alert-dismissible.fade.show(role="alert")
              i.fa-solid.fa-triangle-exclamation.me-2
              | #{error}
              button.btn-close(type="button" data-bs-dismiss="alert" aria-label="Close")

          form(method="POST" action=(isEdit ? `/assets/edit/${asset.AssetId}` : "/assets/create"))
            .row.g-3.mb-4
              .col-md-6
                label.form-label.fw-semibold(for="UniqueId") Unique ID *
                input#UniqueId.form-control(type="text" name="UniqueId" value=asset.UniqueId required placeholder="e.g. AST-10001" readonly)
                small.text-muted.x-small Automatically generated unique identifier tag.
              .col-md-6
                label.form-label.fw-semibold(for="SerialNumber") Serial Number *
                input#SerialNumber.form-control(type="text" name="SerialNumber" value=asset.SerialNumber required placeholder="e.g. SN-XYZ123")
                small.text-muted.x-small Hardware serial number.

              .col-md-6
                .d-flex.justify-content-between.align-items-center.mb-1
                  label.form-label.fw-semibold.mb-0(for="CategoryId") Asset Category *
                  button.btn.btn-link.btn-sm.p-0.text-primary(type="button" data-bs-toggle="modal" data-bs-target="#addCategoryModal")
                    i.fa-solid.fa-plus.me-1
                    | Add New
                select#CategoryId.form-select(name="CategoryId" required)
                  option(value="") -- Select Category --
                  each cat in categories
                    option(value=cat.CategoryId selected=(asset.CategoryId === cat.CategoryId)) #{cat.CategoryName}
              .col-md-6
                label.form-label.fw-semibold(for="Value") Asset Cost (₹) *
                input#Value.form-control(type="number" step="0.01" min="0" name="Value" value=asset.Value required placeholder="e.g. 45000.00")

              .col-md-6
                label.form-label.fw-semibold(for="Quantity") Quantity *
                input#Quantity.form-control(type="number" min="1" name="Quantity" value=(asset.Quantity || 1) required placeholder="e.g. 1")

              .col-md-6
                label.form-label.fw-semibold(for="Make") Make (Manufacturer) *
                input#Make.form-control(type="text" name="Make" value=asset.Make required placeholder="e.g. Dell, Samsung, Bosch")
              .col-md-6
                label.form-label.fw-semibold(for="Model") Model *
                input#Model.form-control(type="text" name="Model" value=asset.Model required placeholder="e.g. Latitude 5420")

              .col-md-6
                .d-flex.justify-content-between.align-items-center.mb-1
                  label.form-label.fw-semibold.mb-0(for="Branch") Location / Branch *
                  button.btn.btn-link.btn-sm.p-0.text-primary(type="button" data-bs-toggle="modal" data-bs-target="#addBranchModal")
                    i.fa-solid.fa-plus.me-1
                    | Add New
                select#Branch.form-select(name="Branch" required)
                  option(value="") -- Select Branch --
                  if branches && branches.length > 0
                    each br in branches
                      option(value=br.BranchName selected=(asset.Branch === br.BranchName)) #{br.BranchName}
                small.text-muted.x-small Physical location when in stock.
              .col-md-6
                label.form-label.fw-semibold(for="PurchaseDate") Purchase Date
                input#PurchaseDate.form-control(type="date" name="PurchaseDate" value=asset.PurchaseDate)

              if isEdit
                .col-md-6
                  label.form-label.fw-semibold(for="Status") Status
                  select#Status.form-select(name="Status" disabled=(asset.Status === 'Scrapped'))
                    option(value="InStock" selected=(asset.Status === 'InStock')) In Stock
                    option(value="Issued" selected=(asset.Status === 'Issued')) Issued
                    option(value="Scrapped" selected=(asset.Status === 'Scrapped')) Scrapped
                  if asset.Status === 'Scrapped'
                    small.text-danger.x-small Scrapped assets status cannot be changed.

            .d-grid
              button.btn.btn-primary.btn-lg(type="submit")
                i.fa-solid.fa-floppy-disk.me-2
                | #{isEdit ? 'Update Asset' : 'Save Asset'}

  #addCategoryModal.modal.fade(tabindex="-1" aria-labelledby="addCategoryModalLabel" aria-hidden="true")
    .modal-dialog.modal-sm.modal-dialog-centered
      .modal-content
        .modal-header.bg-dark.text-white
          h6.modal-title.fw-bold#addCategoryModalLabel
            i.fa-solid.fa-tags.me-2
            | Add Category
          button.btn-close.btn-close-white(type="button" data-bs-dismiss="modal" aria-label="Close")
        form(action="/categories/create" method="POST")
          input(type="hidden" name="_redirect" value=(isEdit ? `/assets/edit/${asset.AssetId}` : '/assets/create'))
          .modal-body.p-3
            label.form-label.fw-semibold.small(for="newCategoryName") Category Name *
            input#newCategoryName.form-control.form-control-sm(type="text" name="CategoryName" required placeholder="e.g. Tablet")
            label.form-label.fw-semibold.small.mt-2(for="newCategoryDesc") Description
            input#newCategoryDesc.form-control.form-control-sm(type="text" name="Description" placeholder="Optional description")
          .modal-footer.p-2
            button.btn.btn-sm.btn-secondary(type="button" data-bs-dismiss="modal") Cancel
            button.btn.btn-sm.btn-primary(type="submit")
              i.fa-solid.fa-floppy-disk.me-1
              | Save Category

  #addBranchModal.modal.fade(tabindex="-1" aria-labelledby="addBranchModalLabel2" aria-hidden="true")
    .modal-dialog.modal-sm.modal-dialog-centered
      .modal-content
        .modal-header.bg-dark.text-white
          h6.modal-title.fw-bold#addBranchModalLabel2
            i.fa-solid.fa-location-dot.me-2
            | Add Branch
          button.btn-close.btn-close-white(type="button" data-bs-dismiss="modal" aria-label="Close")
        form(action="/branches/create" method="POST")
          input(type="hidden" name="_redirect" value=(isEdit ? `/assets/edit/${asset.AssetId}` : '/assets/create'))
          .modal-body.p-3
            label.form-label.fw-semibold.small(for="newBranchName") Branch Name *
            input#newBranchName.form-control.form-control-sm(type="text" name="BranchName" required placeholder="e.g. Mumbai")
          .modal-footer.p-2
            button.btn.btn-sm.btn-secondary(type="button" data-bs-dismiss="modal") Cancel
            button.btn.btn-sm.btn-primary(type="submit")
              i.fa-solid.fa-floppy-disk.me-1
              | Save Branch

  script.
    document.addEventListener('DOMContentLoaded', function() {
      var categorySelect = document.getElementById('CategoryId');
      var uniqueIdInput = document.getElementById('UniqueId');
      var isEdit = !{isEdit ? 'true' : 'false'};

      if (!isEdit && categorySelect && uniqueIdInput) {
        categorySelect.addEventListener('change', function() {
          var categoryId = this.value;
          if (!categoryId) {
            uniqueIdInput.value = '';
            return;
          }
          fetch('/assets/next-unique-id?categoryId=' + categoryId)
            .then(function(res) { return res.json(); })
            .then(function(data) {
              if (data && data.uniqueId) {
                uniqueIdInput.value = data.uniqueId;
              }
            })
            .catch(function(err) {
              console.error('Error fetching next unique ID:', err);
            });
        });

        // Trigger change initially if a category is already selected
        if (categorySelect.value) {
          categorySelect.dispatchEvent(new Event('change'));
        }
      }
    });
