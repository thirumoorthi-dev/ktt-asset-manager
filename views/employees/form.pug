extends ../layout

block content
  .row.justify-content-center
    .col-lg-9
      .card.border-0.shadow-sm
        .card-header.bg-transparent.border-bottom.py-3.d-flex.justify-content-between.align-items-center
          h4.fw-bold.mb-0 #{isEdit ? 'Edit Employee' : 'Add Employee'}
          a.btn.btn-sm.btn-outline-secondary(href="/employees") 
            i.fa-solid.fa-arrow-left.me-1
            | Back to List
        .card-body.p-4
          if error
            .alert.alert-danger.alert-dismissible.fade.show(role="alert")
              i.fa-solid.fa-triangle-exclamation.me-2
              | #{error}
              button.btn-close(type="button" data-bs-dismiss="alert" aria-label="Close")

          form#employeeForm(method="POST" action=(isEdit ? `/employees/edit/${employee.EmployeeId}` : "/employees/create"))
            .row.g-3.mb-4
              .col-md-6
                label.form-label.fw-semibold(for="EmployeeCode") Employee Code *
                input#EmployeeCode.form-control(type="text" name="EmployeeCode" value=employee.EmployeeCode required placeholder="e.g. EMP-001" readonly)
                small.text-muted.x-small Automatically generated unique identifier code.
              .col-md-6
                label.form-label.fw-semibold(for="EmployeeName") Employee Name *
                input#EmployeeName.form-control(type="text" name="EmployeeName" value=employee.EmployeeName required placeholder="e.g. Amit Sharma")
              
              .col-md-6
                label.form-label.fw-semibold(for="Email") Email Address *
                input#Email.form-control(type="email" name="Email" value=employee.Email required placeholder="e.g. amit@kttelematic.com")
              .col-md-6
                label.form-label.fw-semibold(for="Phone") Phone Number
                input#Phone.form-control(type="text" name="Phone" value=employee.Phone placeholder="e.g. +91 9876543210")
              
              .col-md-6
                .d-flex.justify-content-between.align-items-center.mb-1
                  label.form-label.fw-semibold.mb-0(for="Branch") Branch Office *
                  button.btn.btn-link.btn-sm.p-0.text-primary(type="button" data-bs-toggle="modal" data-bs-target="#addBranchModal")
                    i.fa-solid.fa-plus.me-1
                    | Add New
                select#Branch.form-select(name="Branch" required)
                  option(value="") -- Select Branch --
                  if branches && branches.length > 0
                    each br in branches
                      option(value=br.BranchName selected=(employee.Branch === br.BranchName)) #{br.BranchName}
              .col-md-6
                .d-flex.justify-content-between.align-items-center.mb-1
                  label.form-label.fw-semibold.mb-0(for="Department") Department *
                  button.btn.btn-link.btn-sm.p-0.text-primary(type="button" data-bs-toggle="modal" data-bs-target="#addDeptModal")
                    i.fa-solid.fa-plus.me-1
                    | Add New
                select#Department.form-select(name="Department" required)
                  option(value="") -- Select Department --
                  if departments && departments.length > 0
                    each dept in departments
                      option(value=dept.DepartmentName selected=(employee.Department === dept.DepartmentName)) #{dept.DepartmentName}
              
              .col-md-6
                label.form-label.fw-semibold(for="IsActive") Status
                select#IsActive.form-select(name="IsActive")
                  option(value="true" selected=(employee.IsActive !== false)) Active
                  option(value="false" selected=(employee.IsActive === false)) Inactive

            .d-grid
              button.btn.btn-primary.btn-lg(type="submit")
                i.fa-solid.fa-floppy-disk.me-2
                | #{isEdit ? 'Update Employee' : 'Save Employee'}

  #addBranchModal.modal.fade(tabindex="-1" aria-labelledby="addBranchModalLabel" aria-hidden="true")
    .modal-dialog.modal-sm.modal-dialog-centered
      .modal-content
        .modal-header.bg-dark.text-white
          h6.modal-title.fw-bold#addBranchModalLabel
            i.fa-solid.fa-location-dot.me-2
            | Add Branch
          button.btn-close.btn-close-white(type="button" data-bs-dismiss="modal" aria-label="Close")
        form(action="/branches/create" method="POST")
          input(type="hidden" name="_redirect" value=(isEdit ? `/employees/edit/${employee.EmployeeId}` : '/employees/create'))
          .modal-body.p-3
            label.form-label.fw-semibold.small(for="newBranchName") Branch Name *
            input#newBranchName.form-control.form-control-sm(type="text" name="BranchName" required placeholder="e.g. Mumbai")
          .modal-footer.p-2
            button.btn.btn-sm.btn-secondary(type="button" data-bs-dismiss="modal") Cancel
            button.btn.btn-sm.btn-primary(type="submit")
              i.fa-solid.fa-floppy-disk.me-1
              | Save Branch

  #addDeptModal.modal.fade(tabindex="-1" aria-labelledby="addDeptModalLabel" aria-hidden="true")
    .modal-dialog.modal-sm.modal-dialog-centered
      .modal-content
        .modal-header.bg-dark.text-white
          h6.modal-title.fw-bold#addDeptModalLabel
            i.fa-solid.fa-building.me-2
            | Add Department
          button.btn-close.btn-close-white(type="button" data-bs-dismiss="modal" aria-label="Close")
        form(action="/departments/create" method="POST")
          input(type="hidden" name="_redirect" value=(isEdit ? `/employees/edit/${employee.EmployeeId}` : '/employees/create'))
          .modal-body.p-3
            label.form-label.fw-semibold.small(for="newDeptName") Department Name *
            input#newDeptName.form-control.form-control-sm(type="text" name="DepartmentName" required placeholder="e.g. Engineering")
          .modal-footer.p-2
            button.btn.btn-sm.btn-secondary(type="button" data-bs-dismiss="modal") Cancel
            button.btn.btn-sm.btn-primary(type="submit")
              i.fa-solid.fa-floppy-disk.me-1
              | Save Department
