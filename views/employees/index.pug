extends ../layout

block content
  .d-flex.justify-content-between.align-items-center.mb-4
    h2.fw-bold.mb-0 Employee Master
    a.btn.btn-primary(href="/employees/create")
      i.fa-solid.fa-user-plus.me-2
      | Add Employee

  .card.border-0.shadow-sm.mb-4
    .card-body.d-flex.align-items-center.py-2
      span.fw-bold.me-3 Filter by Status:
      .btn-group(role="group" aria-label="Status filters")
        a.btn.btn-sm.btn-outline-secondary(href="/employees?status=all" class=(currentStatusFilter === 'all' ? 'active' : '')) All
        a.btn.btn-sm.btn-outline-success(href="/employees?status=active" class=(currentStatusFilter === 'active' ? 'active' : '')) Active
        a.btn.btn-sm.btn-outline-danger(href="/employees?status=inactive" class=(currentStatusFilter === 'inactive' ? 'active' : '')) Inactive

  .card.border-0.shadow-sm
    .card-body.p-4
      .table-responsive
        table#employeesTable.table.table-striped.table-hover.align-middle(style="width: 100%")
          thead.table-dark
            tr
              th Code
              th Name
              th Email
              th Phone
              th Branch
              th Department
              th Status
              th Actions
          tbody
            if employees && employees.length > 0
              each emp in employees
                tr
                  td
                    span.font-monospace.fw-bold.text-secondary #{emp.EmployeeCode}
                  td #{emp.EmployeeName}
                  td #{emp.Email}
                  td #{emp.Phone || '-'}
                  td #{emp.Branch || '-'}
                  td #{emp.Department || '-'}
                  td
                    if emp.IsActive
                      span.badge.bg-success-subtle.text-success.px-2.py-1.border.border-success-subtle Active
                    else
                      span.badge.bg-danger-subtle.text-danger.px-2.py-1.border.border-danger-subtle Inactive
                  td
                    a.btn.btn-sm.btn-outline-primary(href=`/employees/edit/${emp.EmployeeId}`)
                      i.fa-solid.fa-pen-to-square.me-1
                      | Edit
            else
              tr
                td.text-center.text-muted(colspan="8") No employees found.
