doctype html
html(lang="en" class="h-100")
  head
    meta(charset="utf-8")
    meta(name="viewport" content="width=device-width, initial-scale=1")
    title #{title} | Asset Tracker
    link(rel="preconnect" href="https://fonts.googleapis.com")
    link(rel="preconnect" href="https://fonts.gstatic.com" crossorigin)
    link(href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet")
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet")
    link(href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet")
    link(href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" rel="stylesheet")
    link(href="/css/style.css" rel="stylesheet")
  body(class="d-flex flex-column vh-100 overflow-hidden bg-light")
    unless isLoginPage
      nav.navbar.navbar-expand-lg.navbar-dark.bg-dark.shadow-sm
        .container
          a.navbar-brand.d-flex.align-items-center(href="/")
            i.fa-solid.fa-boxes-packing.me-2.text-info
            span.fw-bold.tracking-wide KT TELEMATICS ASSETS
          button.navbar-toggler(type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation")
            span.navbar-toggler-icon
          #navbarNav.collapse.navbar-collapse
            ul.navbar-nav.ms-auto
              li.nav-item
                a.nav-link(href="/" class=(title === 'Dashboard' ? 'active' : '')) 
                  i.fa-solid.fa-chart-pie.me-1
                  | Dashboard
              li.nav-item
                a.nav-link(href="/employees" class=(title.includes('Employee') ? 'active' : '')) 
                  i.fa-solid.fa-users.me-1
                  | Employees
              li.nav-item
                a.nav-link(href="/assets" class=(title === 'Asset Master' || (title.includes('Asset') && !title.includes('Stock') && !title.includes('History') && !title.includes('Issue') && !title.includes('Return')) ? 'active' : '')) 
                  i.fa-solid.fa-laptop-code.me-1
                  | Asset Master
              li.nav-item
                a.nav-link(href="/assets/stock" class=(title === 'Stock View' ? 'active' : '')) 
                  i.fa-solid.fa-warehouse.me-1
                  | Stock View
              li.nav-item.dropdown
                a.nav-link.dropdown-toggle(href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false" class=(title.includes('Issue') || title.includes('Return') || title.includes('History') ? 'active' : ''))
                  i.fa-solid.fa-handshake.me-1
                  | Actions
                ul.dropdown-menu.dropdown-menu-dark.dropdown-menu-end
                  li
                    a.dropdown-item(href="/assets/issue") Issue Asset
                  li
                    a.dropdown-item(href="/assets/return") Return Asset
                  li
                    hr.dropdown-divider
                  li
                    a.dropdown-item(href="/assets/history") Asset History
              li.nav-item.ms-lg-2
                a.nav-link.text-danger.fw-medium(href="/logout")
                  i.fa-solid.fa-right-from-bracket.me-1
                  | Logout

    if isLoginPage
      block content
    else
      main.flex-grow-1.overflow-y-auto(style="padding-top: 24px; padding-bottom: 24px;")
        .container
          block content
      footer.footer.py-3.bg-white.border-top.mt-auto
        .container.text-center
          span.text-muted.small &copy; 2026 KT Telematic Solutions Private Limited. All rights reserved.

    script(src="https://code.jquery.com/jquery-3.7.0.min.js")
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js")
    script(src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js")
    script(src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js")
    script(src="/js/main.js")
